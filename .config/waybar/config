{
    "layer": "top",
    "margin-top": 5,
    "margin-bottom": 0,
    "margin-left": 5,
    "margin-right": 5,
    
    "modules-left": [
        "custom/rofi",
        "hyprland/window"
    ],
    
    "modules-center": [
        "hyprland/workspaces"
    ],
    
    "modules-right": [
        "custom/hyprshot",
        "custom/waypaper",
        "pulseaudio",
        "network",
        "clock"
    ],

    "custom/rofi": {
    	"format": "",
    	"tooltip": false,
    	"on-click": "rofi -show drun"
    },
    
    "hyprland/window": {
    	"format": "{}",
    	"tooltip": false
    },
    
    "custom/hyprshot": {
    	"format": "",
    	"tooltip": false,
    	"on-click": "hyprshot -m region"
    },

    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "default": "󰥲",
        "active": "",
        "persistent": "󰥲"
      },
      "persistent-workspaces": {
          "*": 3
        }

    },

    "custom/waypaper": {
    	"format": "",
    	"tooltip": false,
    	"on-click": "waypaper"
    },
    
     "pulseaudio": {
        "format": " 󰋋  {volume}%",
        "format-muted": "󰟎",
        "on-click": "pavucontrol"
    },
    
    "network": {
        "format-wifi": "󰤥",
        "format-disconnected": "󰤭",
        "tooltip-format": "{essid}",
        "on-click": "nmtui"
    },

    "clock": {
    	"format": "{:%H:%M}",
    	"tooltip-format": "{:%A, %B %d, %Y}"
    }
}
